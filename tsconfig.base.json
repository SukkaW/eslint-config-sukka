{
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "${configDir}/node_modules/.cache/tsconfig.tsbuildinfo",
    "target": "es2020",
    "lib": [
      "ESNext"
    ],
    "module": "preserve",
    "moduleResolution": "bundler",
    "types": ["node"],
    "resolveJsonModule": true,
    "noEmit": true,
    "esModuleInterop": true,
    "preserveSymlinks": true,
    "strict": true,
    "strictNullChecks": true,
    "skipLibCheck": true
  }
}
